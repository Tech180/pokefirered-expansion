    "components": [
      {
        "type": "raw",
        "content": "#define UNOWN_MISC_INFO(letter, _noFlip, frontWidth, frontHeight, backWidth, backHeight, backYOffset)   \\\n    {                                                                                                   \\\n        .baseHP        = 48,                                                                            \\\n        .baseAttack    = 72,                                                                            \\\n        .baseDefense   = 48,                                                                            \\\n        .baseSpeed     = 48,                                                                            \\\n        .baseSpAttack  = 72,                                                                            \\\n        .baseSpDefense = 48,                                                                            \\\n        .types = MON_TYPES(TYPE_PSYCHIC),                                                               \\\n        .catchRate = 225,                                                                               \\\n        .expYield = (P_UPDATED_EXP_YIELDS >= GEN_5) ? 118 : 61,                                         \\\n        .evYield_Attack = 1,                                                                            \\\n        .evYield_SpAttack = 1,                                                                          \\\n        .genderRatio = MON_GENDERLESS,                                                                  \\\n        .eggCycles = 40,                                                                                \\\n        .friendship = STANDARD_FRIENDSHIP,                                                              \\\n        .growthRate = GROWTH_MEDIUM_FAST,                                                               \\\n        .eggGroups = MON_EGG_GROUPS(EGG_GROUP_NO_EGGS_DISCOVERED),                                      \\\n        .abilities = { ABILITY_LEVITATE, ABILITY_NONE, ABILITY_NONE },                                  \\\n        .bodyColor = BODY_COLOR_BLACK,                                                                  \\\n        .noFlip = _noFlip,                                                                              \\\n        .speciesName = _(\"Unown\"),                                                                      \\\n        .cryId = CRY_UNOWN,                                                                             \\\n        .natDexNum = NATIONAL_DEX_UNOWN,                                                                \\\n        .categoryName = _(\"Symbol\"),                                                                    \\\n        .height = 5,                                                                                    \\\n        .weight = 50,                                                                                   \\\n        .description = gUnownPokedexText,                                                               \\\n        .pokemonScale = 411,                                                                            \\\n        .pokemonOffset = 2,                                                                             \\\n        .trainerScale = 256,                                                                            \\\n        .trainerOffset = 0,                                                                             \\\n        .frontPic = gMonFrontPic_Unown ##letter,                                                        \\\n        .frontPicSize = MON_COORDS_SIZE(frontWidth, frontHeight),                                       \\\n        .frontPicYOffset = 16,                                                                          \\\n        .frontAnimFrames = sAnims_SingleFramePlaceHolder,                                               \\\n        .frontAnimId = ANIM_ZIGZAG_FAST,                                                                \\\n        .enemyMonElevation = 8,                                                                         \\\n        .backPic = gMonBackPic_Unown ##letter,                                                          \\\n        .backPicSize = MON_COORDS_SIZE(backWidth, backHeight),                                          \\\n        .backPicYOffset = backYOffset,                                                                  \\\n        .backAnimId = BACK_ANIM_SHRINK_GROW_VIBRATE,                                                    \\\n        .palette = gMonPalette_Unown,                                                                   \\\n        .shinyPalette = gMonShinyPalette_Unown,                                                         \\\n        .iconSprite = gMonIcon_Unown ##letter,                                                          \\\n        .iconPalIndex = 0,                                                                              \\\n        .pokemonJumpType = PKMN_JUMP_TYPE_NONE,                                                         \\\n        SHADOW(0, 3, SHADOW_SIZE_S)                                                                     \\\n        FOOTPRINT(Unown)                                                                                \\\n        OVERWORLD(                                                                                      \\\n            sPicTable_Unown ##letter,                                                                   \\\n            SIZE_32x32,                                                                                 \\\n            SHADOW_SIZE_M,                                                                              \\\n            TRACKS_NONE,                                                                                \\\n            sAnimTable_Following,                                                                       \\\n            gOverworldPalette_Unown,                                                                    \\\n            gShinyOverworldPalette_Unown,                                                               \\\n        )                                                                                               \\\n        .teachingType = TM_ILLITERATE,                                                                  \\\n        .levelUpLearnset = sUnownLevelUpLearnset,                                                       \\\n        .teachableLearnset = sUnownTeachableLearnset,                                                   \\\n        .formSpeciesIdTable = sUnownFormSpeciesIdTable,                                                 \\\n    }"
