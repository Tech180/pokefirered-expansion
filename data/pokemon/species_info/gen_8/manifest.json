e = gMonIcon_AlcremieStrawberryVanillaCream, /*AlcremieStrawberry##cream##*/  \\\n        .iconPalIndex = 1,                                                                      \\\n        .pokemonJumpType = PKMN_JUMP_TYPE_SLOW,                                                 \\\n        SHADOW(0, 5, SHADOW_SIZE_S)                                                             \\\n        FOOTPRINT(Alcremie)                                                                     \\\n        OVERWORLD(                                                                              \\\n            sPicTable_AlcremieStrawberry, /*Alcremie ##sweet*/                                  \\\n            SIZE_32x32,                                                                         \\\n            SHADOW_SIZE_M,                                                                      \\\n            TRACKS_FOOT,                                                                        \\\n            sAnimTable_Following,                                                               \\\n            gOverworldPalette_AlcremieStrawberryVanillaCream, /*Alcremie ##sweet##cream*/       \\\n            gShinyOverworldPalette_AlcremieStrawberryVanillaCream /*Alcremie ##sweet##cream*/   \\\n        )                                                                                       \\\n        .levelUpLearnset = sAlcremieLevelUpLearnset,                                            \\\n        .teachableLearnset = sAlcremieTeachableLearnset,                                        \\\n        .formSpeciesIdTable = sAlcremieFormSpeciesIdTable,                                      \\\n        .formChangeTable = sAlcremieFormChangeTable,                                            \\\n    }"
