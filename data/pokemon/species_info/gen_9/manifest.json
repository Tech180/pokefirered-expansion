erpon##Form2,                                                                                   \\\n            SIZE_32x32,                                                                                                 \\\n            SHADOW_SIZE_M,                                                                                              \\\n            TRACKS_FOOT,                                                                                                \\\n            sAnimTable_Following,                                                                                       \\\n            gOverworldPalette_Ogerpon##Form2,                                                                           \\\n            gShinyOverworldPalette_Ogerpon##Form2                                                                       \\\n        )                                                                                                               \\\n        .levelUpLearnset = sOgerponLevelUpLearnset,                                                                     \\\n        .teachableLearnset = sOgerponTeachableLearnset,                                                                 \\\n        .formSpeciesIdTable = sOgerponFormSpeciesIdTable,                                                               \\\n        .formChangeTable = sOgerpon##Form1##FormChangeTable,                                                            \\\n        .isSubLegendary = TRUE,                                                                                         \\\n        .isTeraForm = isTeraform,                                                                                       \\\n        .perfectIVCount = LEGENDARY_PERFECT_IV_COUNT,                                                                   \\\n    }"
